[Unit]
Description=Disposable Exec API
After=network.target redis-server.service docker.service
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/opt/disposable-exec/app
EnvironmentFile=/opt/disposable-exec/app/.env
ExecStart=/opt/disposable-exec/app/.venv/bin/python -m uvicorn disposable_exec.server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target